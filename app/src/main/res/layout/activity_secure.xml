<?xml version="1.0" encoding="utf-8"?>
<!-- ConstraintLayout presents the authorization result without extra complexity. -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <!-- Title identifies the private activity that demonstrates caller UID checks. -->
    <TextView
        android:id="@+id/textViewSecureTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="SecureActivity"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- TextView displays either authorized secure data or an unauthorized warning. -->
    <TextView
        android:id="@+id/textViewSecureData"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Security result"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textViewSecureTitle" />

    <!-- Retour button calls finish() to return to MainActivity or the previous screen. -->
    <Button
        android:id="@+id/buttonSecureBack"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Retour"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textViewSecureData" />

</androidx.constraintlayout.widget.ConstraintLayout>
